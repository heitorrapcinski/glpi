# ─── Version control ──────────────────────────────────────────────────────
.git/
.gitignore

# ─── Kiro spec files (not needed in images) ───────────────────────────────
.kiro/

# ─── Build output (rebuilt inside Docker) ────────────────────────────────
target/

# ─── Documentation ────────────────────────────────────────────────────────
*.md
docs/

# ─── Environment and secrets ──────────────────────────────────────────────
.env
.env.*

# ─── Tests ────────────────────────────────────────────────────────────────
tests/
**/src/test/

# ─── IDE files ────────────────────────────────────────────────────────────
.idea/
.vscode/

# ─── Logs ─────────────────────────────────────────────────────────────────
*.log
logs/
