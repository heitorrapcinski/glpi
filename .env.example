# ─────────────────────────────────────────────────────────────────────────────
# GLPI Microservices Backend — Environment Variables
#
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# The .env file is ignored by Git (see .gitignore).
# All variables below are REQUIRED — docker-compose.yml has no fallback defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Project Version (must match pom.xml) ─────────────────────────────────
VERSION=1.0.6

# ─── Infrastructure Ports ─────────────────────────────────────────────────
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
MONGODB_PORT=27017

# ─── MongoDB Credentials ─────────────────────────────────────────────────
MONGO_ROOT_USER=glpi
MONGO_ROOT_PASSWORD=glpi_secret

# ─── Microservice Ports ──────────────────────────────────────────────────
API_GATEWAY_PORT=8080
IDENTITY_SERVICE_PORT=8081
TICKET_SERVICE_PORT=8082
PROBLEM_SERVICE_PORT=8083
CHANGE_SERVICE_PORT=8084
ASSET_SERVICE_PORT=8085
SLA_SERVICE_PORT=8086
NOTIFICATION_SERVICE_PORT=8087
KNOWLEDGE_SERVICE_PORT=8088

# ─── Kafka ────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─── JWT Keys (leave empty for ephemeral dev keys) ───────────────────────
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRY_SECONDS=3600
JWT_REFRESH_TOKEN_EXPIRY_SECONDS=604800

# ─── Security ────────────────────────────────────────────────────────────
BCRYPT_COST=12

# ─── MongoDB URIs (per service) ──────────────────────────────────────────
IDENTITY_MONGODB_URI=mongodb://glpi:glpi_secret@mongodb:27017/glpi_identity?authSource=admin
TICKET_MONGODB_URI=mongodb://glpi:glpi_secret@mongodb:27017/glpi_tickets?authSource=admin
PROBLEM_MONGODB_URI=mongodb://glpi:glpi_secret@mongodb:27017/glpi_problems?authSource=admin
CHANGE_MONGODB_URI=mongodb://glpi:glpi_secret@mongodb:27017/glpi_changes?authSource=admin
ASSET_MONGODB_URI=mongodb://glpi:glpi_secret@mongodb:27017/glpi_assets?authSource=admin
SLA_MONGODB_URI=mongodb://glpi:glpi_secret@mongodb:27017/glpi_sla?authSource=admin
NOTIFICATION_MONGODB_URI=mongodb://glpi:glpi_secret@mongodb:27017/glpi_notifications?authSource=admin
KNOWLEDGE_MONGODB_URI=mongodb://glpi:glpi_secret@mongodb:27017/glpi_knowledge?authSource=admin

# ─── Service URLs (internal Docker network) ──────────────────────────────
IDENTITY_SERVICE_URL=http://identity-service:8081
TICKET_SERVICE_URL=http://ticket-service:8082
PROBLEM_SERVICE_URL=http://problem-service:8083
CHANGE_SERVICE_URL=http://change-service:8084
ASSET_SERVICE_URL=http://asset-service:8085
SLA_SERVICE_URL=http://sla-service:8086
NOTIFICATION_SERVICE_URL=http://notification-service:8087
KNOWLEDGE_SERVICE_URL=http://knowledge-service:8088

# ─── API Gateway ─────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=1000

# ─── SLA ─────────────────────────────────────────────────────────────────
ESCALATION_CRON=0 */5 * * * *

# ─── Notification / SMTP ─────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
NOTIFICATION_SENDER_EMAIL=noreply@glpi.local
